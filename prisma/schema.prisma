// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String     @id @default(cuid())
  email         String     @unique
  emailVerified DateTime?
  name          String?
  image         String?
  role          UserRole   @default(USER)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  accounts             Account[]
  sessions             Session[]
  tokenizerModels      TokenizerModel[]
  trainingDatasets     TrainingDataset[]
  usageLogs            UsageLog[]
  savedTokenizations   SavedTokenization[]

  @@index([email])
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model TokenizerModel {
  id           String   @id @default(cuid())
  name         String
  description  String?
  vocabulary   Json     // Stored as JSON {token -> id}
  merges       Json     // Stored as JSON array of merge pairs
  vocabSize    Int
  createdBy    String
  user         User     @relation(fields: [createdBy], references: [id], onDelete: Cascade)
  isPublic     Boolean  @default(false)
  downloadCount Int     @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  usageLogs            UsageLog[]
  savedTokenizations   SavedTokenization[]

  @@index([createdBy])
  @@index([isPublic])
}

model TrainingDataset {
  id          String   @id @default(cuid())
  name        String
  description String?
  content     String   @db.Text
  size        Int      // Character count
  createdBy   String
  user        User     @relation(fields: [createdBy], references: [id], onDelete: Cascade)
  isPublic    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([createdBy])
  @@index([isPublic])
}

model UsageLog {
  id              String   @id @default(cuid())
  userId          String
  modelId         String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  model           TokenizerModel @relation(fields: [modelId], references: [id], onDelete: Cascade)
  inputTokens     Int
  outputTokens    Int
  action          String   // "encode", "decode", "train", etc.
  duration        Int      // milliseconds
  estimatedCost   Float    @default(0)
  timestamp       DateTime @default(now())

  @@index([userId])
  @@index([modelId])
  @@index([timestamp])
}

model SavedTokenization {
  id          String   @id @default(cuid())
  userId      String
  modelId     String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  model       TokenizerModel @relation(fields: [modelId], references: [id], onDelete: Cascade)
  title       String
  inputText   String   @db.Text
  tokens      Json     // Stored as JSON array of token IDs
  tokenCount  Int
  savedAt     DateTime @default(now())

  @@index([userId])
  @@index([modelId])
}

enum UserRole {
  USER
  ADMIN
}
